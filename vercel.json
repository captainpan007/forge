{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@forge/web",
  "outputDirectory": "apps/web/.next",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install",
  "ignoreCommand": "cd ../.. && npx turbo-ignore @forge/web",
  "regions": ["sin1"],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "crons": []
}
