# ──────────────────────────────────────────
# Anthropic Claude API (BYOK)
# ──────────────────────────────────────────
# 用户可以在 /settings 里填自己的 key；这里是开发用的 fallback
ANTHROPIC_API_KEY=
# 可选：覆盖 JARVIS 用的模型（默认 claude-haiku-4-5-20251001）
# 进阶选项：claude-sonnet-4-6（需 sonnet 访问权限）/ claude-opus-4-6（最贵）
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ──────────────────────────────────────────
# Clerk (Auth)
# https://dashboard.clerk.com → 创建应用
# ──────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# 登录/注册成功后跳转到 dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ──────────────────────────────────────────
# Turso (libSQL / SQLite)
# https://turso.tech → 创建免费 DB
# ──────────────────────────────────────────
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ──────────────────────────────────────────
# 应用配置
# ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=forge

# ──────────────────────────────────────────
# 网络代理（仅本地开发用 — 中国 IP 连 Anthropic API 需要）
# ──────────────────────────────────────────
# Vercel / 海外服务器：⚠ 不要设这个，留空即可
# 本地开发：填你的代理地址（Clash / V2Ray 等）
# HTTPS_PROXY=http://127.0.0.1:7897

# ──────────────────────────────────────────
# 可选高级配置
# ──────────────────────────────────────────
# 自定义 Anthropic 端点（走第三方代理 / 自建反向代理时用）
# ANTHROPIC_BASE_URL=
